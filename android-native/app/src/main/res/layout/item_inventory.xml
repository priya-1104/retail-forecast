<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Info details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_inv_product_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Product Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_inv_sku"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SKU: PROD-001"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tv_inv_reorder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reorder Point: 10 | EOQ: 50"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Stock level info -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tv_inv_quantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="54 units"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <!-- Stock status label -->
            <TextView
                android:id="@+id/tv_inv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In Stock"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/success"
                android:background="@color/primary_light"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginTop="6dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
