# Flask configuration
FLASK_APP=app.py
FLASK_DEBUG=1
SECRET_KEY=your_session_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here

# Database URL (SQLite default, PostgreSQL in production)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///instance/demand_forecasting.db

# Storage folder configurations (optional overrides)
# UPLOAD_FOLDER=app/static/uploads
# MODEL_FOLDER=instance/models
